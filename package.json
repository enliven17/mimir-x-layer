{
  "name": "mimir",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "clean": "rm -rf .next",
    "build": "next build",
    "start": "next start",
    "oracle": "tsx --env-file-if-exists=.env.local agents/oracle/index.ts",
    "oracle:challenge": "AUTO_CHALLENGE=1 tsx --env-file-if-exists=.env.local agents/oracle/index.ts",
    "market-creator": "tsx --env-file-if-exists=.env.local agents/market-creator/index.ts",
    "workers": "concurrently --names oracle,creator --kill-others-on-fail -c blue,magenta \"npm:oracle\" \"npm:market-creator\"",
    "seed": "npx tsx scripts/seed-claims.ts",
    "seed:dry": "DRY_RUN=1 npx tsx scripts/seed-claims.ts",
    "wallets:generate": "npx tsx scripts/generate-wallets.ts",
    "contract:compile": "npx tsx scripts/compile-contract.ts",
    "deploy:contract": "npx tsx deploy/deploy.ts",
    "test:smoke": "node --import tsx --test tests/node/api-validation.test.ts tests/node/challenge-opportunities.test.ts tests/node/claim-moderation-route.test.ts tests/node/claim-moderation-sanitize.test.ts tests/node/claim-quality.test.ts tests/node/db-index.test.ts tests/node/explore-filters.test.ts tests/node/vs-xmtp-eligibility.test.ts tests/node/xmtp-installation-limit-error.test.ts",
    "warm:vs-index": "tsx scripts/warm-vs-index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@fontsource/maple-mono": "^5.2.6",
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-query": "^5.100.10",
    "@types/ws": "^8.18.1",
    "@wagmi/connectors": "^5.7.7",
    "@xmtp/browser-sdk": "^7.0.0",
    "concurrently": "^9.2.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.383.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "nextjs-toploader": "^3.9.17",
    "ogl": "^1.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "sonner": "^1.7.0",
    "tsx": "^4.19.0",
    "viem": "^2.47.6",
    "wagmi": "^3.6.15",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.0",
    "postcss": "^8",
    "solc": "^0.8.28",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  }
}
