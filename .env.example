# =============================================================================
# Mimir × X Layer — environment variables
# Copy to .env.local; never commit secrets.
# =============================================================================

# ── Deployed contract ────────────────────────────────────────────────────────
# Mimir.sol deployed on X Layer Testnet (chainId 195).
# Set automatically by: npm run deploy:contract
# NEXT_PUBLIC_CONTRACT_ADDRESS=0x...

# Block number where the contract was deployed. Used by the stats / agents
# pages to chunk eth_getLogs scans in 10k-block batches.
# NEXT_PUBLIC_DEPLOY_BLOCK=1

# ── X Layer RPC ──────────────────────────────────────────────────────────────
# Default: https://testrpc.xlayer.tech (X Layer Testnet, chainId 195).
# Override if you have a private RPC endpoint with higher rate limits.
# NEXT_PUBLIC_XLAYER_RPC=https://testrpc.xlayer.tech
# XLAYER_RPC=https://testrpc.xlayer.tech     # server-only override

# Explorer: https://www.oklink.com/xlayer-test
# Faucet  : https://www.okx.com/xlayer/faucet

# ── Agent signing keys (NEVER commit) ────────────────────────────────────────
# Generated locally with: npm run wallets:generate
# That writes wallets.local.json (git-ignored) with deployer + oracle + creator
# keys. For production, set the env vars directly and never rely on the file.

# Deployer (one-time, used by deploy/deploy.ts)
# DEPLOYER_PRIVATE_KEY=0x...

# Oracle agent (signs resolveClaim + auto-challenge calls)
# ORACLE_PRIVATE_KEY=0x...
# ORACLE_ADDRESS=0x...

# Market creator agent (signs createClaim calls)
# CREATOR_PRIVATE_KEY=0x...
# CREATOR_ADDRESS=0x...

# ── Oracle LLM ───────────────────────────────────────────────────────────────
# One key is enough; Gemini is preferred when both are set.
# Force a provider with LLM_PROVIDER=gemini|anthropic.
# GEMINI_API_KEY=...                       # https://aistudio.google.com/apikey
# ANTHROPIC_API_KEY=sk-ant-...             # https://console.anthropic.com
# LLM_PROVIDER=gemini
# ORACLE_LLM_MODEL=gemini-2.5-flash        # or claude-sonnet-4-6

# ── Auto-challenger (optional) ───────────────────────────────────────────────
# When enabled, the oracle agent auto-stakes on open claims it believes are
# mispriced. Disabled by default.
# AUTO_CHALLENGE=1
# CHALLENGE_STAKE_OKB=0.05      # OKB per challenge (default 0.05)
# CHALLENGE_CONFIDENCE=80       # min confidence % to auto-stake (default 80)

# ── Market creator (optional knobs) ──────────────────────────────────────────
# CREATOR_STAKE_OKB=0.05        # OKB per market created (default 0.05)
# MAX_CLAIMS_PER_RUN=5          # max new claims per 6h run (default 5)
# RUN_INTERVAL_HOURS=6          # hours between runs (default 6)

# ── Demo mode (no wallet needed) ─────────────────────────────────────────────
# Lets the UI route writes through a server-held key instead of the user's
# wallet. Useful for demo videos.
# NEXT_PUBLIC_DEMO_MODE=1
# NEXT_PUBLIC_DEMO_MODE_LABEL=X Layer Testnet demo
# DEMO_CREATOR_PRIVATE_KEY=0x...
# DEMO_CHALLENGER_PRIVATE_KEY=0x...
# DEMO_SIGNER_PRIVATE_KEY=0x...     # fallback for all actions

# ── XMTP messaging (optional, E2E encrypted) ─────────────────────────────────
# NEXT_PUBLIC_XMTP_ENV=dev          # local | dev | production
# NEXT_PUBLIC_FEATURE_XMTP=1
# NEXT_PUBLIC_XMTP_APP_VERSION=mimir/0.1.0

# ── Neon Postgres read-index (optional) ──────────────────────────────────────
# Contract is the source of truth. Neon is just a denormalised cache used by
# /explorer, /dashboard, and the challenge-opportunities API. The app boots
# without it; those routes will return 500 and the rest still works.
# DATABASE_URL=postgresql://<user>:<pwd>@<host>/<db>?sslmode=require
# CRON_SECRET=

# ── Claim drafting (AI-assisted create flow) ─────────────────────────────────
# NEXT_PUBLIC_FEATURE_SOURCE_DRAFTS=1
# CLAIM_DRAFT_MODEL=gemini-2.5-flash

# ── Claim moderation ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_FEATURE_CLAIM_MODERATION=1
# CLAIM_MODERATION_MODEL=gemini-2.5-flash
